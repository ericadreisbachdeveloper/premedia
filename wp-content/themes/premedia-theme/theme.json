{
    "$schema": "https://schemas.wp.org/wp/6.7/theme.json",
    "version": 3,
    "settings": {
        "border": {
            "color": true,
            "radius": true,
            "style": true,
            "width": true
        },
        "color": {
            "defaultDuotone": false,
            "defaultGradients": false,
            "defaultPalette": false,
            "palette": [
                {
                    "color": "#FFFFFF",
                    "name": "Base",
                    "slug": "base"
                },
                {
                    "color": "#111111",
                    "name": "Contrast",
                    "slug": "contrast"
                },
                {
                    "color": "#555555",
                    "name": "Text",
                    "slug": "text-gray"
                },
                {
                    "color": "#002a55",
                    "name": "Accent 1",
                    "slug": "accent-1"
                },
                {
                    "color": "#004181",
                    "name": "Accent 2",
                    "slug": "accent-2"
                },
                {
                    "color": "#00708a",
                    "name": "Accent 3",
                    "slug": "accent-3"
                },
                {
                    "color": "#4e9ed3",
                    "name": "Accent 4",
                    "slug": "accent-4"
                },
                {
                    "color": "#7a7c81",
                    "name": "Accent 5",
                    "slug": "accent-5"
                },
                {
                    "color": "#f9ae1e",
                    "name": "Accent 6",
                    "slug": "accent-6"
                },
                {
                    "color": "#f9fafb",
                    "name": "Accent 7",
                    "slug": "accent-7"
                },
                {
                    "color": "#fdf7e9",
                    "name": "Accent 8",
                    "slug": "accent-8"
                }
            ]
        },
        "dimensions": {
            "minHeight": true
        },
        "layout": {
            "contentSize": "1200px",
            "wideSize": "1200px"
        },
        "spacing": {
            "padding": true,
            "margin": true,
            "blockGap": true,
            "defaultSpacingSizes": false,
            "spacingSizes": [
                {
                    "name": "Mobile Hide",
                    "size": "clamp(0px, calc((100vw - 767px) * (48 / 767)), 48px)",
                    "slug": "10"
                },
                {
                    "name": "Tiny",
                    "size": "8px",
                    "slug": "20"
                },
                {
                    "name": "X-Small",
                    "size": "2rem",
                    "slug": "30"
                },
                {
                    "name": "Small",
                    "size": "2.5rem",
                    "slug": "40"
                },
                {
                    "name": "Regular",
                    "size": "clamp(24px, calc((100vw - 600px) * (48 / 600)), 48px)",
                    "slug": "50"
                },
                {
                    "name": "Large",
                    "size": "clamp(30px, 7vw, 70px)",
                    "slug": "60"
                },
                {
                    "name": "X-Large",
                    "size": "clamp(50px, 7vw, 90px)",
                    "slug": "70"
                },
                {
                    "name": "XX-Large",
                    "size": "clamp(70px, 10vw, 140px)",
                    "slug": "80"
                }
            ],
            "units": [
                "%",
                "px",
                "em",
                "rem",
                "vh",
                "vw"
            ]
        },
        "typography": {
            "lineHeight": true,
            "fontSize": true,
            "fontWeight": true,
            "writingMode": true,
            "defaultFontSizes": false,
            "fluid": true,
            "fontSizes": [
                {
                    "fluid": false,
                    "name": "Small",
                    "size": "0.875rem",
                    "slug": "small"
                },
                {
                    "fluid": {
                        "min": "0.875rem",
                        "max": "1.25rem"
                    },
                    "name": "Medium",
                    "size": "1rem",
                    "slug": "medium"
                },
                {
                    "fluid": {
                        "min": "1.25rem",
                        "max": "2.25rem"
                    },
                    "name": "Large",
                    "size": "1.38rem",
                    "slug": "large"
                },
                {
                    "fluid": {
                        "min": "1.5rem",
                        "max": "3rem"
                    },
                    "name": "Extra Large",
                    "size": "1.75rem",
                    "slug": "x-large"
                },
                {
                    "fluid": {
                        "min": "2.15rem",
                        "max": "3rem"
                    },
                    "name": "Extra Extra Large",
                    "size": "2.15rem",
                    "slug": "xx-large"
                }
            ]
        },
        "blocks": {
            "core/group": {
                "spacing": {
                    "padding": true,
                    "margin": true,
                    "blockGap": true
                }
            }
        }
    }
}