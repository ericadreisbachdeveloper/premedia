                    "name": "Contrast",
                    "slug": "contrast"
                },
                {
                    "color": "#FFEE58",
                    "name": "Accent 1",
                    "slug": "accent-1"
                },
                {
                    "color": "#F6CFF4",
                    "name": "Accent 2",
                    "slug": "accent-2"
                },
                {
                    "color": "#503AA8",
                    "name": "Accent 3",
                    "slug": "accent-3"
                },
                {
                    "color": "#686868",
                    "name": "Accent 4",
                    "slug": "accent-4"
                },
                {
                    "color": "#FBFAF3",
                    "name": "Accent 5",
                    "slug": "accent-5"
                },
                {
                    "color": "color-mix(in srgb, currentColor 20%, transparent)",
                    "name": "Accent 6",
                    "slug": "accent-6"
